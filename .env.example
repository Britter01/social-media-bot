# =====================================================================
# Brite Tech Lifestyle — social media automation
# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).
# =====================================================================

# --- Brand identity ---------------------------------------------------
BRAND_NAME="Brite Tech Lifestyle"
BRAND_FOUNDER="Dean Britter"
BRAND_TAGLINE="Technology, beautifully lived."

# --- Runtime behaviour ------------------------------------------------
# DRY_RUN=true logs what would be posted without calling external APIs.
DRY_RUN=true
LOG_LEVEL=INFO
TIMEZONE=Europe/London
# How many posts to create per content-pipeline run.
POSTS_PER_RUN=1

# --- Research agent ---------------------------------------------------
# Minimum brand-relevance score (0-100) a trending topic must reach to be
# turned into a post. Lower-scoring topics are stored but not used.
MIN_TOPIC_RELEVANCE=70
# How many of the top-scoring topics to turn into posts per research run.
TOPICS_PER_RUN=3

# --- Anthropic (captions + hashtags) ----------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Google Imagen 4 Fast (thumbnails) --------------------------------
GOOGLE_API_KEY=
IMAGEN_MODEL=imagen-4.0-fast-generate-001

# --- HeyGen (video with cloned voice) ---------------------------------
HEYGEN_API_KEY=
HEYGEN_VOICE_ID=
HEYGEN_AVATAR_ID=

# --- Supabase (database + storage) ------------------------------------
SUPABASE_URL=
SUPABASE_KEY=
# Public Storage bucket for generated media (thumbnails, etc.)
SUPABASE_BUCKET=media

# --- Instagram (Graph API) --------------------------------------------
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- X / Twitter (API v2, OAuth 1.0a) ---------------------------------
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- LinkedIn (UGC Posts API) -----------------------------------------
LINKEDIN_ACCESS_TOKEN=
# e.g. urn:li:person:XXXX or urn:li:organization:XXXX
LINKEDIN_AUTHOR_URN=

# --- YouTube (Data API v3) --------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- TikTok (Content Posting API) -------------------------------------
TIKTOK_ACCESS_TOKEN=
